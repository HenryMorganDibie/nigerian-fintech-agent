# ┌──────────────────────────────────────────────────────────────┐
# │  NaijaFinAI v3 — Environment Configuration                   │
# │                                                              │
# │  STEP 1: cp .env.example .env                               │
# │  STEP 2: Add your GROQ key (free — no credit card)          │
# │           Get it at: https://console.groq.com               │
# │  STEP 3: uvicorn main:app --reload --port 8000              │
# └──────────────────────────────────────────────────────────────┘

# ── PRIMARY (Free — recommended for testing) ───────────────────
# Get free key at https://console.groq.com — no credit card
GROQ_API_KEY=

# ── OPTIONAL (only add if you have these) ─────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Default provider — KEEP AS groq for free testing ──────────
DEFAULT_LLM_PROVIDER=groq

# ── Model overrides (defaults are already set) ────────────────
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# GOOGLE_MODEL=gemini-1.5-pro

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
