# ┌─────────────────────────────────────────────────────────────┐
# │  NaijaFinAI — Environment Configuration                     │
# │                                                             │
# │  STEP 1: Copy this file:  cp .env.example .env             │
# │  STEP 2: Fill in at least ONE API key below                 │
# │  STEP 3: Set DEFAULT_LLM_PROVIDER to match that key        │
# │                                                             │
# │  Recommended for free testing: GROQ (no credit card)       │
# │  Get key at: https://console.groq.com                      │
# └─────────────────────────────────────────────────────────────┘

# ── LLM Provider Keys (fill in at least ONE) ──────────────────
# Leave unused ones blank — don't delete them

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo   # free tier default; override with gpt-4o if you have paid access

# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-2.1  # free tier default; override with claude-sonnet-4-20250514 if you have paid access

# Google Gemini — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-flash-lite-latest  # free tier default; override with gemini-2.5-pro if you have paid access

# Groq (FREE, fastest) — https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile  # free tier default

# ── Default Provider ──────────────────────────────────────────
# Must match whichever key you filled in above
# Options: openai | anthropic | google | groq
DEFAULT_LLM_PROVIDER=openai

# ── CORS (don't change for local dev) ────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
