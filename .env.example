# ┌─────────────────────────────────────────────────────────────┐
# │  NaijaFinAI — Environment Configuration                     │
# │                                                             │
# │  STEP 1: Copy this file:  cp .env.example .env             │
# │  STEP 2: Fill in at least ONE API key below                 │
# │  STEP 3: Set DEFAULT_LLM_PROVIDER to match that key        │
# │                                                             │
# │  Recommended for free testing: GROQ (no credit card)       │
# │  Get key at: https://console.groq.com                      │
# └─────────────────────────────────────────────────────────────┘

# ── LLM Provider Keys (fill in at least ONE) ──────────────────
# Leave unused ones blank — don't delete them

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Groq (FREE, fastest) — https://console.groq.com
GROQ_API_KEY=

# ── Default Provider ──────────────────────────────────────────
# Must match whichever key you filled in above
# Options: openai | anthropic | google | groq
DEFAULT_LLM_PROVIDER=groq

# ── CORS (don't change for local dev) ────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
