# ┌──────────────────────────────────────────────────────────────────┐
# │  NaijaFinAI v3 — Environment Configuration                       │
# │                                                                  │
# │  STEP 1: cp .env.example .env                                   │
# │  STEP 2: Add GROQ_API_KEY (free at https://console.groq.com)    │
# │  STEP 3: uvicorn main:app --reload --port 8000                  │
# └──────────────────────────────────────────────────────────────────┘

# ── PRIMARY (free, no credit card) ────────────────────────────────
GROQ_API_KEY=

# ── Groq model config (both free) ─────────────────────────────────
# Primary — best quality
GROQ_MODEL=llama-3.3-70b-versatile
# Fallback — auto-used when primary hits rate limit
GROQ_FALLBACK_MODEL=llama3-70b-8192

# ── Optional providers ─────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Default provider ───────────────────────────────────────────────
DEFAULT_LLM_PROVIDER=groq

# ── Feature store (optional — uses in-memory if not set) ──────────
# REDIS_URL=redis://localhost:6379

# ── CORS ──────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
